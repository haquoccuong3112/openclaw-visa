# secrets — never commit (these live only on this box)
scan-ocr.env
google-service-account.json
*.pem
*.key

# temporary scratch / debug files
tmp/

# daily memory logs (ephemeral, not for version control)
memory/

# bot-generated / churny
scan-ho-so/runs/
scan-ho-so/test-runs/
scan-ho-so/_checkpoints/
scan-ho-so/group_registry.json
scan-ho-so/group_registry.json.bak
scan-ho-so/recent_cases.json
scan-ho-so/recent_cases.json.tmp

# python caches
**/__pycache__/
*.pyc
*.pyo

# editor / "rm + heredoc" backups
*.bak
*.bak.*
*.bak-*
*.last-good

# one-time bootstrap ritual (deleted after first run anyway)
BOOTSTRAP.md

# skills/ — keep ONLY our custom skill in git; stock ClawHub skills are re-installable
skills/*
!skills/scan-ho-so-pipeline/

# OS / node junk
.DS_Store
*.swp
node_modules/

# per-workspace OpenClaw state dir (created by the gateway) — runtime state, never commit
.openclaw/
