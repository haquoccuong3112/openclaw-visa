# ~/.openclaw/ is mostly OpenClaw STATE + CREDENTIALS. Default: ignore EVERYTHING;
# un-ignore ONLY the agent workspace. NEVER add credentials/, identity/, telegram/,
# openclaw.json, exec-approvals.json, agents/, logs/, tasks/, flows/, memory/, plugins/,
# devices/, completions/, canvas/, tui/, tools/, ... — they're machine-local state.
/*
!/.gitignore
!/CLAUDE.md
!/workspace/

# belt-and-suspenders for things under workspace/ (workspace/.gitignore also covers these):
workspace/scan-ocr.env
workspace/google-service-account.json
workspace/**/*.pem
workspace/**/*.key
workspace/scan-ho-so/runs/
workspace/scan-ho-so/test-runs/
workspace/scan-ho-so/group_registry.json
workspace/scan-ho-so/group_registry.json.bak
workspace/**/__pycache__/
workspace/**/*.pyc
workspace/**/*.bak
workspace/**/*.bak-*
# keep only our custom skill in git; the stock ClawHub skills are re-installable
workspace/skills/*
!workspace/skills/scan-ho-so-pipeline/
